{
  "name": "omniwa-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone web operations console for OmniWA Platform.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "design:check": "node scripts/check-table-contract.mjs && node scripts/check-drawer-contract.mjs && node scripts/check-dialog-contract.mjs",
    "contract:check": "node scripts/check-contract-compatibility.mjs",
    "architecture:check": "node scripts/check-architecture.mjs",
    "bundle:check": "node scripts/check-bundle.mjs",
    "check": "pnpm design:check && pnpm contract:check && pnpm architecture:check && pnpm typecheck && pnpm build && pnpm bundle:check",
    "contract:sync": "cp ../omniwa/docs/api/openapi/omniwa-v1.openapi.json contracts/omniwa-v1.openapi.json",
    "api:generate": "openapi-typescript contracts/omniwa-v1.openapi.json -o src/api/generated/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "openapi-fetch": "^0.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "openapi-typescript": "^7.4.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
